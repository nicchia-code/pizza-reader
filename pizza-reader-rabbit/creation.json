{
  "name": "Pizza Reader",
  "description": "Reader one-word-at-a-time per Rabbit r1. Importa libri .pizzabook.json via QR HTTPS.",
  "version": "0.1.0",
  "entry": "index.html",
  "themeColor": "#fff4df",
  "viewport": {
    "width": 240,
    "height": 282
  },
  "hardware": {
    "sideClick": "play_pause_or_next_chapter_at_chapter_end",
    "longPressStart": "hold_start",
    "longPressEnd": "hold_stop",
    "scrollUp": "previous_word",
    "scrollDown": "next_word"
  }
}
